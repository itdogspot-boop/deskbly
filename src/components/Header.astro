---
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">🖥️ Deskbly</a></h2>
		<button class="menu-toggle" aria-label="Toggle menu">☰</button>
		<div class="nav-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/category/desks">Desks</HeaderLink>
			<HeaderLink href="/category/chairs">Chairs</HeaderLink>
			<HeaderLink href="/category/accessories">Accessories</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
	</nav>
</header>

<script>
	const toggle = document.querySelector('.menu-toggle');
	const navLinks = document.querySelector('.nav-links');
	if (toggle && navLinks) {
		toggle.addEventListener('click', () => {
			navLinks.classList.toggle('open');
		});
	}
</script>

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
		position: sticky;
		top: 0;
		z-index: 100;
	}
	h2 {
		margin: 0;
		font-size: 1.2em;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
		color: rgb(var(--black));
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 960px;
		margin: 0 auto;
	}
	.nav-links {
		display: flex;
	}
	.nav-links a {
		padding: 1em 0.7em;
		color: rgb(var(--black));
		border-bottom: 3px solid transparent;
		text-decoration: none;
		font-size: 0.95em;
		font-weight: 600;
	}
	.nav-links a.active {
		border-bottom-color: var(--accent);
		color: var(--accent);
	}
	.nav-links a:hover {
		color: var(--accent);
	}
	.menu-toggle {
		display: none;
		background: none;
		border: none;
		font-size: 1.5em;
		cursor: pointer;
		padding: 0.5em;
	}
	@media (max-width: 720px) {
		.menu-toggle {
			display: block;
		}
		.nav-links {
			display: none;
			position: absolute;
			top: 100%;
			left: 0;
			right: 0;
			background: white;
			flex-direction: column;
			box-shadow: 0 4px 12px rgba(var(--black), 10%);
		}
		.nav-links.open {
			display: flex;
		}
		.nav-links a {
			padding: 0.8em 1.5em;
			border-bottom: 1px solid rgba(var(--gray-light), 1);
		}
	}
</style>
