---
const today = new Date();
---

<footer>
	<div class="footer-grid">
		<div class="footer-col">
			<h4>🖥️ Deskbly</h4>
			<p>Honest reviews and buying guides for your home office. No fluff, no fake reviews.</p>
		</div>
		<div class="footer-col">
			<h4>Categories</h4>
			<ul>
				<li><a href="/category/desks">Desks</a></li>
				<li><a href="/category/chairs">Chairs</a></li>
				<li><a href="/category/accessories">Accessories</a></li>
			</ul>
		</div>
		<div class="footer-col">
			<h4>Company</h4>
			<ul>
				<li><a href="/about">About Us</a></li>
				<li><a href="/contact">Contact</a></li>
				<li><a href="/privacy-policy">Privacy Policy</a></li>
				<li><a href="/affiliate-disclosure">Affiliate Disclosure</a></li>
			</ul>
		</div>
	</div>
	<div class="footer-bottom">
		<p>&copy; {today.getFullYear()} Deskbly. All rights reserved.</p>
	</div>
</footer>

<style>
	footer {
		background: rgb(var(--gray-dark));
		color: rgba(255, 255, 255, 0.8);
		padding: 3em 1em 1.5em;
		margin-top: 4em;
	}
	.footer-grid {
		display: grid;
		grid-template-columns: 2fr 1fr 1fr;
		gap: 2em;
		max-width: 960px;
		margin: 0 auto;
	}
	.footer-col h4 {
		color: white;
		margin-bottom: 0.8em;
		font-size: 1em;
	}
	.footer-col p {
		font-size: 0.85em;
		line-height: 1.6;
		margin: 0;
	}
	.footer-col ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.footer-col ul li {
		margin-bottom: 0.4em;
	}
	.footer-col ul a {
		color: rgba(255, 255, 255, 0.7);
		text-decoration: none;
		font-size: 0.85em;
	}
	.footer-col ul a:hover {
		color: white;
	}
	.footer-bottom {
		max-width: 960px;
		margin: 2em auto 0;
		padding-top: 1.5em;
		border-top: 1px solid rgba(255, 255, 255, 0.15);
		text-align: center;
		font-size: 0.8em;
	}
	@media (max-width: 720px) {
		.footer-grid {
			grid-template-columns: 1fr;
			gap: 1.5em;
		}
	}
</style>
