---
const today = new Date();
---

<footer class="site-footer">
	<div class="footer-inner">
		<div class="footer-main">
			<div class="footer-brand">
				<div class="logo">
					<span class="logo-icon">◈</span>
					<span class="logo-text">Deskbly</span>
				</div>
				<p>Honest reviews and buying guides for your home office. No fluff, no fake reviews. We test the gear so you don't waste money.</p>
				<div class="social-icons">
					<a href="https://instagram.com/deskbly" target="_blank" rel="noopener" aria-label="Instagram">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="18" cy="6" r="1.5" fill="currentColor" stroke="none"/></svg>
					</a>
					<a href="https://pinterest.com/deskbly" target="_blank" rel="noopener" aria-label="Pinterest">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.08 3.16 9.43 7.63 11.1-.11-.94-.2-2.4.04-3.44.22-.94 1.41-5.97 1.41-5.97s-.36-.72-.36-1.78c0-1.67.97-2.92 2.17-2.92 1.02 0 1.52.77 1.52 1.69 0 1.03-.66 2.57-.99 3.99-.28 1.19.6 2.17 1.78 2.17 2.13 0 3.77-2.25 3.77-5.49 0-2.87-2.06-4.88-5.01-4.88-3.41 0-5.42 2.56-5.42 5.21 0 1.03.4 2.14.89 2.74a.36.36 0 0 1 .08.35l-.33 1.36c-.05.22-.18.27-.4.16-1.5-.7-2.44-2.89-2.44-4.65 0-3.79 2.75-7.26 7.93-7.26 4.16 0 7.4 2.97 7.4 6.93 0 4.14-2.61 7.46-6.23 7.46-1.22 0-2.36-.63-2.75-1.38l-.75 2.85c-.27 1.04-1 2.35-1.49 3.15C9.57 23.81 10.76 24 12 24c6.63 0 12-5.37 12-12S18.63 0 12 0z"/></svg>
					</a>
					<a href="https://facebook.com/deskbly" target="_blank" rel="noopener" aria-label="Facebook">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.07c0-6.63-5.37-12-12-12S0 5.44 0 12.07c0 5.99 4.39 10.95 10.13 11.85v-8.39H7.08v-3.47h3.05V9.43c0-3.01 1.79-4.67 4.53-4.67 1.31 0 2.69.24 2.69.24v2.95h-1.52c-1.49 0-1.95.93-1.95 1.88v2.25h3.33l-.53 3.47h-2.8v8.39C19.61 23.02 24 18.06 24 12.07z"/></svg>
					</a>
				</div>
			</div>
			
			<div class="footer-newsletter">
				<h4>📬 Stay Updated</h4>
				<p>Get the latest deals and reviews delivered to your inbox. No spam, unsubscribe anytime.</p>
				<form class="newsletter-form" onsubmit="event.preventDefault(); alert('Thanks for subscribing! (Newsletter coming soon)');">
					<input type="email" placeholder="Your email address" required />
					<button type="submit">Subscribe</button>
				</form>
			</div>
		</div>
		
		<div class="footer-links">
			<div class="link-group">
				<h4>Categories</h4>
				<ul>
					<li><a href="/category/desks">Standing Desks</a></li>
					<li><a href="/category/chairs">Office Chairs</a></li>
					<li><a href="/category/accessories">Accessories</a></li>
					<li><a href="/category/desks">Budget Desks</a></li>
				</ul>
			</div>
			<div class="link-group">
				<h4>Company</h4>
				<ul>
					<li><a href="/about">About Us</a></li>
					<li><a href="/contact">Contact</a></li>
					<li><a href="/privacy-policy">Privacy Policy</a></li>
					<li><a href="/affiliate-disclosure">Affiliate Disclosure</a></li>
				</ul>
			</div>
			<div class="link-group">
				<h4>Popular</h4>
				<ul>
					<li><a href="/blog/best-standing-desks-under-300">Best Standing Desks</a></li>
					<li><a href="/blog/best-ergonomic-chairs-2026">Best Office Chairs</a></li>
					<li><a href="/blog/home-office-setup-under-500">Setup Under $500</a></li>
				</ul>
			</div>
		</div>
	</div>
	<div class="footer-bottom">
		<p>&copy; {today.getFullYear()} Deskbly. All rights reserved. | Built with honest reviews, no fluff.</p>
	</div>
</footer>

<style>
	.site-footer {
		background: #0f172a;
		color: rgba(255, 255, 255, 0.7);
		padding: 4em 1em 1.5em;
		margin-top: 4em;
	}
	.footer-inner {
		max-width: 1100px;
		margin: 0 auto;
	}
	.footer-main {
		display: grid;
		grid-template-columns: 1.2fr 1fr;
		gap: 3em;
		padding-bottom: 2em;
		border-bottom: 1px solid rgba(255, 255, 255, 0.1);
	}
	.logo {
		display: flex;
		align-items: center;
		gap: 0.5em;
		margin-bottom: 1em;
	}
	.logo-icon {
		font-size: 1.6em;
		color: #38bdf8;
	}
	.logo-text {
		font-size: 1.3em;
		font-weight: 800;
		color: white;
	}
	.footer-brand p {
		font-size: 0.9em;
		line-height: 1.6;
		margin-bottom: 1.2em;
		max-width: 320px;
	}
	.social-icons {
		display: flex;
		gap: 0.8em;
	}
	.social-icons a {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 38px;
		height: 38px;
		background: rgba(255, 255, 255, 0.1);
		border-radius: 10px;
		color: rgba(255, 255, 255, 0.7);
		transition: all 0.2s;
	}
	.social-icons a:hover {
		background: #38bdf8;
		color: white;
		transform: translateY(-2px);
	}
	.footer-newsletter h4 {
		color: white;
		font-size: 1.1em;
		margin: 0 0 0.5em 0;
	}
	.footer-newsletter p {
		font-size: 0.85em;
		margin-bottom: 1em;
		line-height: 1.5;
	}
	.newsletter-form {
		display: flex;
		gap: 0.5em;
	}
	.newsletter-form input {
		flex: 1;
		padding: 0.7em 1em;
		border: 2px solid rgba(255, 255, 255, 0.15);
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.05);
		color: white;
		font-size: 0.9em;
	}
	.newsletter-form input::placeholder {
		color: rgba(255, 255, 255, 0.4);
	}
	.newsletter-form input:focus {
		outline: none;
		border-color: #38bdf8;
	}
	.newsletter-form button {
		padding: 0.7em 1.2em;
		background: #38bdf8;
		color: #0f172a;
		border: none;
		border-radius: 8px;
		font-weight: 700;
		font-size: 0.9em;
		cursor: pointer;
		transition: all 0.2s;
	}
	.newsletter-form button:hover {
		background: #7dd3fc;
	}
	.footer-links {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2em;
		padding: 2em 0;
	}
	.link-group h4 {
		color: white;
		font-size: 0.85em;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		margin-bottom: 1em;
		font-weight: 600;
	}
	.link-group ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.link-group ul li {
		margin-bottom: 0.6em;
	}
	.link-group ul a {
		color: rgba(255, 255, 255, 0.6);
		text-decoration: none;
		font-size: 0.9em;
		transition: color 0.2s;
	}
	.link-group ul a:hover {
		color: #38bdf8;
	}
	.footer-bottom {
		max-width: 1100px;
		margin: 0 auto;
		padding-top: 1.5em;
		border-top: 1px solid rgba(255, 255, 255, 0.1);
		text-align: center;
		font-size: 0.8em;
		color: rgba(255, 255, 255, 0.4);
	}
	@media (max-width: 800px) {
		.footer-main {
			grid-template-columns: 1fr;
		}
		.footer-links {
			grid-template-columns: repeat(2, 1fr);
		}
	}
	@media (max-width: 500px) {
		.footer-links {
			grid-template-columns: 1fr;
		}
		.newsletter-form {
			flex-direction: column;
		}
	}
</style>
