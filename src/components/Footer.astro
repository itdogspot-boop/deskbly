---
// src/components/Footer.astro
const year = new Date().getFullYear();
---
<footer>
  <div class="footer-inner">
    <p>© {year} Deskbly — Ergonomic home office tips & reviews</p>
    <nav>
      <a href="/about/">About</a>
      <a href="/contact/">Contact</a>
      <a href="/privacy-policy/">Privacy Policy</a>
      <a href="/disclaimer/">Disclaimer</a>
    </nav>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid #eee;
    margin-top: 4rem;
    padding: 2rem 1.5rem;
  }
  .footer-inner {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
    justify-content: space-between;
  }
  footer p {
    font-size: 0.85rem;
    color: #888;
    margin: 0;
  }
  footer nav {
    display: flex;
    gap: 1.25rem;
  }
  footer nav a {
    font-size: 0.85rem;
    color: #888;
    text-decoration: none;
  }
  footer nav a:hover { color: #111; }
</style>
