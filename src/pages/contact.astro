---
// src/pages/contact.astro
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<html lang="en">
  <head>
    <BaseHead
      title="Contact Deskbly"
      description="Get in touch with Deskbly. We'd love to hear your questions, feedback, or topic suggestions."
    />
    <style>
      .page { max-width: 600px; margin: 3rem auto; padding: 0 1.5rem; }
      h1 { font-size: 2rem; font-weight: 800; color: #111; margin-bottom: 0.5rem; }
      p { line-height: 1.8; color: #555; margin-bottom: 1.5rem; }
      .contact-box {
        background: #f8f9fa;
        border: 1px solid #eee;
        border-radius: 10px;
        padding: 2rem;
        margin-top: 1.5rem;
      }
      .contact-box p { margin: 0; font-size: 1rem; color: #444; }
      .contact-box a {
        color: #059669;
        font-weight: 600;
        text-decoration: none;
      }
      .contact-box a:hover { text-decoration: underline; }
    </style>
  </head>
  <body>
    <Header />
    <main class="page">
      <h1>Contact Us</h1>
      <p>Have a question, a topic you'd like us to cover, or a product you think we should review? We'd love to hear from you.</p>
      <div class="contact-box">
        <p>📧 Email us at: <a href="mailto:hello@deskbly.com">hello@deskbly.com</a></p>
      </div>
      <p style="margin-top:1.5rem;font-size:0.9rem;color:#888">
        We typically respond within 1–2 business days.
      </p>
    </main>
    <Footer />
  </body>
</html>
