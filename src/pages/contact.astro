---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Contact Us — Deskbly" description="Get in touch with the Deskbly team." />
	</head>
	<body>
		<Header />
		<main>
			<h1>Contact Us</h1>
			<p>
				Have a question, suggestion, or want to work with us? We'd love to hear from you.
			</p>

			<h2>Get in Touch</h2>
			<p>
				📧 <strong>Email:</strong> <a href="mailto:hello@deskbly.com">hello@deskbly.com</a>
			</p>

			<h2>Business Inquiries</h2>
			<p>
				For product reviews, partnerships, or advertising, please email us with the subject line 
				<strong>"Business Inquiry"</strong> and we'll get back to you within 48 hours.
			</p>

			<h2>Found an Error?</h2>
			<p>
				If you spot incorrect information, broken links, or outdated prices in any of our articles, 
				please let us know. We take accuracy seriously and will fix it promptly.
			</p>
		</main>
		<Footer />
	</body>
</html>
