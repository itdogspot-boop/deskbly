---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Contact Us — Deskbly" description="Get in touch with the Deskbly team." />
	</head>
	<body>
		<Header />
		<main>
			<section class="page-header">
				<h1>Contact Us</h1>
				<p>Have a question, suggestion, or want to work with us? We'd love to hear from you.</p>
			</section>

			<div class="contact-grid">
				<div class="contact-info">
					<h2>Get in Touch</h2>
					<p>📧 <strong>Email:</strong> <a href="mailto:hello@deskbly.com">hello@deskbly.com</a></p>
					
					<h3>Business Inquiries</h3>
					<p>For product reviews, partnerships, or advertising, please email us with the subject line <strong>"Business Inquiry"</strong> and we'll get back to you within 48 hours.</p>

					<h3>Found an Error?</h3>
					<p>If you spot incorrect information, broken links, or outdated prices in any of our articles, please let us know. We take accuracy seriously and will fix it promptly.</p>
					
					<div class="response-time">
						<span class="icon">⏱️</span>
						<p><strong>Average response time:</strong> 24-48 hours</p>
					</div>
				</div>

				<div class="contact-form-wrapper">
					<div id="form-message" class="form-message" style="display: none;">
						<span class="success-icon">✓</span>
						<h3>Message Sent!</h3>
						<p>Thank you for reaching out. We'll get back to you within 24-48 hours.</p>
					</div>
					
					<h2>Send us a Message</h2>
					<form class="contact-form" id="contact-form">
						<input type="hidden" name="_next" value="https://deskbly.com/contact" />
						<div class="form-row">
							<div class="form-group">
								<label for="firstname">First Name *</label>
								<input type="text" id="firstname" name="firstname" required placeholder="John" />
							</div>
							<div class="form-group">
								<label for="lastname">Last Name *</label>
								<input type="text" id="lastname" name="lastname" required placeholder="Doe" />
							</div>
						</div>
						<div class="form-group">
							<label for="email">Email Address *</label>
							<input type="email" id="email" name="email" required placeholder="john@example.com" />
						</div>
						<div class="form-group">
							<label for="phone">Phone Number</label>
							<input type="tel" id="phone" name="phone" placeholder="+1 (555) 123-4567" />
						</div>
						<div class="form-group">
							<label for="subject">Subject *</label>
							<input type="text" id="subject" name="subject" required placeholder="What is this about?" />
						</div>
						<div class="form-group">
							<label for="message">Message *</label>
							<textarea id="message" name="message" rows="5" required placeholder="Tell us what's on your mind..."></textarea>
						</div>
						<button type="submit" class="btn-submit">Send Message →</button>
					</form>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>

<script>
  const form = document.getElementById('contact-form');
  const messageDiv = document.getElementById('form-message');
  
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const formData = new FormData(form);
    formData.append('_subject', formData.get('subject'));
    
    try {
      const response = await fetch('https://formspree.io/f/mnjgblqw', {
        method: 'POST',
        body: formData,
        headers: {
          'Accept': 'application/json'
        }
      });
      
      if (response.ok) {
        form.style.display = 'none';
        messageDiv.style.display = 'block';
        form.reset();
      } else {
        alert('Something went wrong. Please try again.');
      }
    } catch (error) {
      alert('Something went wrong. Please try again.');
    }
  });
</script>

<style>
	.contact-grid {
		display: grid;
		grid-template-columns: 1fr 1.2fr;
		gap: 3em;
		margin-top: 2em;
	}
	.contact-info {
		background: white;
		padding: 2em;
		border-radius: 16px;
		border: 1px solid #e2e8f0;
	}
	.contact-info h2 {
		margin-top: 0;
	}
	.contact-info h3 {
		font-size: 1.1em;
		margin-top: 1.5em;
		margin-bottom: 0.5em;
	}
	.contact-info p {
		color: #64748b;
		line-height: 1.6;
	}
	.contact-info a {
		color: #38bdf8;
	}
	.response-time {
		display: flex;
		align-items: center;
		gap: 0.8em;
		margin-top: 2em;
		padding: 1em;
		background: #f0f9ff;
		border-radius: 8px;
	}
	.response-time .icon {
		font-size: 1.5em;
	}
	.response-time p {
		margin: 0;
		color: #0369a1;
	}
	.contact-form-wrapper {
		background: white;
		padding: 2em;
		border-radius: 16px;
		border: 1px solid #e2e8f0;
	}
	.contact-form-wrapper h2 {
		margin-top: 0;
	}
	.form-message {
		background: #f0fdf4;
		border: 2px solid #22c55e;
		border-radius: 12px;
		padding: 1.5em;
		text-align: center;
		margin-bottom: 1.5em;
	}
	.form-message .success-icon {
		display: inline-block;
		width: 40px;
		height: 40px;
		background: #22c55e;
		color: white;
		border-radius: 50%;
		line-height: 40px;
		font-size: 1.5em;
		margin-bottom: 0.5em;
	}
	.form-message h3 {
		color: #166534;
		margin: 0 0 0.3em 0;
	}
	.form-message p {
		color: #15803d;
		margin: 0;
	}
	.form-row {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1em;
	}
	.form-group {
		margin-bottom: 1.2em;
	}
	.form-group label {
		display: block;
		margin-bottom: 0.4em;
		font-weight: 600;
		font-size: 0.9em;
		color: #334155;
	}
	.form-group input,
	.form-group textarea {
		width: 100%;
		padding: 0.8em 1em;
		border: 2px solid #e2e8f0;
		border-radius: 10px;
		font-size: 1em;
		transition: border-color 0.2s;
		box-sizing: border-box;
	}
	.form-group input:focus,
	.form-group textarea:focus {
		outline: none;
		border-color: #38bdf8;
	}
	.btn-submit {
		width: 100%;
		padding: 1em;
		background: #38bdf8;
		color: #0f172a;
		border: none;
		border-radius: 10px;
		font-size: 1em;
		font-weight: 700;
		cursor: pointer;
		transition: all 0.2s;
	}
	.btn-submit:hover {
		background: #7dd3fc;
		transform: translateY(-2px);
	}
	@media (max-width: 800px) {
		.contact-grid {
			grid-template-columns: 1fr;
		}
		.form-row {
			grid-template-columns: 1fr;
		}
	}
</style>
