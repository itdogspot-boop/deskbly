---
// src/pages/index.astro
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 6);
---
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      * { box-sizing: border-box; }
      body { margin: 0; font-family: system-ui, sans-serif; color: #333; }

      /* Hero */
      .hero {
        background: #f8fffe;
        border-bottom: 1px solid #eee;
        padding: 4rem 1.5rem;
        text-align: center;
      }
      .hero h1 {
        font-size: clamp(1.8rem, 4vw, 2.8rem);
        font-weight: 800;
        color: #111;
        line-height: 1.2;
        margin: 0 0 1rem;
      }
      .hero h1 span { color: #059669; }
      .hero p {
        font-size: 1.1rem;
        color: #555;
        max-width: 520px;
        margin: 0 auto 2rem;
        line-height: 1.7;
      }
      .hero-ctas { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
      .btn-primary {
        background: #059669;
        color: #fff;
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        font-weight: 600;
        text-decoration: none;
        font-size: 0.95rem;
        transition: background 0.2s;
      }
      .btn-primary:hover { background: #047857; }
      .btn-secondary {
        background: #fff;
        color: #111;
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        font-weight: 600;
        text-decoration: none;
        font-size: 0.95rem;
        border: 1px solid #ddd;
      }

      /* Trust bar */
      .trust-bar {
        background: #fff;
        border-bottom: 1px solid #eee;
        padding: 0.75rem 1.5rem;
        display: flex;
        justify-content: center;
        gap: 2rem;
        flex-wrap: wrap;
      }
      .trust-bar span { font-size: 0.85rem; color: #666; }

      /* Posts */
      .posts-section {
        max-width: 800px;
        margin: 3rem auto;
        padding: 0 1.5rem;
      }
      .posts-section h2 {
        font-size: 1.4rem;
        font-weight: 700;
        margin-bottom: 1.5rem;
        color: #111;
      }
      .post-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.5rem;
      }
      .post-card {
        border: 1px solid #eee;
        border-radius: 10px;
        overflow: hidden;
        text-decoration: none;
        color: inherit;
        transition: box-shadow 0.2s;
        display: block;
      }
      .post-card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.08); }
      .post-card img {
        width: 100%;
        height: 180px;
        object-fit: cover;
      }
      .post-card-img-placeholder {
        width: 100%;
        height: 180px;
        background: #f0fdf4;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
      }
      .post-card-body { padding: 1.25rem; }
      .post-card-date { font-size: 0.8rem; color: #999; margin-bottom: 0.5rem; }
      .post-card h3 {
        font-size: 1rem;
        font-weight: 700;
        margin: 0 0 0.5rem;
        color: #111;
        line-height: 1.4;
      }
      .post-card p {
        font-size: 0.875rem;
        color: #666;
        margin: 0;
        line-height: 1.6;
      }

      /* Categories */
      .categories {
        background: #f8f9fa;
        border-top: 1px solid #eee;
        border-bottom: 1px solid #eee;
        padding: 2.5rem 1.5rem;
        margin-bottom: 0;
      }
      .categories-inner {
        max-width: 800px;
        margin: 0 auto;
      }
      .categories h2 {
        font-size: 1.4rem;
        font-weight: 700;
        margin-bottom: 1.25rem;
        color: #111;
      }
      .cat-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
        gap: 1rem;
      }
      .cat-card {
        background: #fff;
        border: 1px solid #eee;
        border-radius: 10px;
        padding: 1.25rem 1rem;
        text-align: center;
        text-decoration: none;
        color: #333;
        transition: border-color 0.2s;
      }
      .cat-card:hover { border-color: #059669; }
      .cat-card .icon { font-size: 1.8rem; margin-bottom: 0.5rem; }
      .cat-card span { font-size: 0.875rem; font-weight: 600; color: #111; }
    </style>
  </head>
  <body>
    <Header />

    <!-- Hero -->
    <section class="hero">
      <h1>Work From Home<br>Without the <span>Back Pain</span></h1>
      <p>Ergonomic home office tips, honest gear reviews, and setup guides — so you can work comfortably all day.</p>
      <div class="hero-ctas">
        <a href="/blog/" class="btn-primary">Read the Blog →</a>
        <a href="/about/" class="btn-secondary">About Deskbly</a>
      </div>
    </section>

    <!-- Trust bar -->
    <div class="trust-bar">
      <span>✓ Honest reviews</span>
      <span>✓ Ergonomist-backed tips</span>
      <span>✓ No fluff, just what works</span>
    </div>

    <!-- Latest posts -->
    <section class="posts-section">
      <h2>Latest Articles</h2>
      {posts.length === 0 ? (
        <p style="color:#999">No posts yet — check back soon!</p>
      ) : (
        <div class="post-grid">
          {posts.map(post => (
            <a href={`/blog/${post.slug}/`} class="post-card">
              {post.data.heroImage
                ? <img src={post.data.heroImage} alt={post.data.title} />
                : <div class="post-card-img-placeholder">📝</div>
              }
              <div class="post-card-body">
                <div class="post-card-date">
                  <FormattedDate date={post.data.pubDate} />
                </div>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      )}
    </section>

    <!-- Categories -->
    <section class="categories">
      <div class="categories-inner">
        <h2>Browse by Topic</h2>
        <div class="cat-grid">
          <a href="/blog/" class="cat-card"><div class="icon">🖥️</div><span>Desk Setups</span></a>
          <a href="/blog/" class="cat-card"><div class="icon">💺</div><span>Ergonomics</span></a>
          <a href="/blog/" class="cat-card"><div class="icon">⌨️</div><span>Gear Reviews</span></a>
          <a href="/blog/" class="cat-card"><div class="icon">💡</div><span>Lighting Tips</span></a>
          <a href="/blog/" class="cat-card"><div class="icon">📋</div><span>Setup Guides</span></a>
          <a href="/blog/" class="cat-card"><div class="icon">💰</div><span>Budget Picks</span></a>
        </div>
      </div>
    </section>

    <Footer />
  </body>
</html>
