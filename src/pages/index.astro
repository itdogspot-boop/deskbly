---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${SITE_TITLE} — Best Home Office Desks, Chairs & Setup Guides`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Your Desk. Done Right.</h1>
				<p>Honest reviews, no fluff buying guides, and setup ideas for your home office. We test the gear so you don't waste money.</p>
				<a href="/blog" class="cta">Browse All Reviews →</a>
			</section>

			<section class="categories">
				<a href="/category/desks">🖥️ Desks</a>
				<a href="/category/chairs">🪑 Chairs</a>
				<a href="/category/accessories">⌨️ Accessories</a>
			</section>

			<section>
				<h2>Latest Reviews</h2>
				<ul class="post-grid">
					{posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								{post.data.heroImage && (
									<Image width={560} height={280} src={post.data.heroImage} alt={post.data.title} />
								)}
								<div class="post-info">
									<span class="category-tag">{post.data.category || 'general'}</span>
									<h4>{post.data.title}</h4>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
									<p class="desc">{post.data.description}</p>
								</div>
							</a>
						</li>
					))}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.category-tag {
		display: inline-block;
		background: rgba(var(--gray-light), 0.8);
		padding: 0.15em 0.6em;
		border-radius: 4px;
		font-size: 0.75em;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: rgb(var(--gray));
		margin-bottom: 0.4em;
	}
	.desc {
		font-size: 0.85em;
		color: rgb(var(--gray));
		margin: 0;
	}
</style>
